# ScrapBro — environment configuration template
# Copy this file to .env and fill in the values you need. All variables are
# optional: ScrapBro runs with sensible defaults when they are unset.

# Serper.dev API key for the Dorks scraper (Google results).
# Free 2500 queries at https://serper.dev — no credit card.
# Without a key, Dorks falls back to DuckDuckGo with conservative delays.
SERPER_API_KEY=

# Residential proxy for LinkedIn / Instagram / Facebook (improves results).
# Format: http://user:password@host:port
PROXY_URL=

# Apify token for Instagram at scale (optional, future use).
APIFY_TOKEN=

# Random delay between requests, in seconds (default 2.0 - 5.0).
SCRAPING_DELAY_MIN=2.0
SCRAPING_DELAY_MAX=5.0

# Default lead limit when --limit is not passed (default 50).
DEFAULT_LIMIT=50

# Output directory for generated .xlsx / .json files (default: output).
OUTPUT_DIR=output
