# ScrapBro — environment configuration template
# Copy this file to .env and fill in the values you need. All variables are
# optional: ScrapBro runs with sensible defaults when they are unset.

# ── APIS ────────────────────────────────────────────────
# Serper.dev API key for the Dorks scraper (Google results).
# Free 2500 queries at https://serper.dev — no credit card.
# Without a key, Dorks falls back to DuckDuckGo with conservative delays.
SERPER_API_KEY=

# Apify token for Instagram at scale (optional, future use).
# Free $5 credits: https://apify.com
APIFY_TOKEN=

# ── PROXIES ─────────────────────────────────────────────
# Residential proxy for LinkedIn / Instagram / MercadoLibre (improves results).
# Format: http://user:password@host:port
PROXY_URL=

# ── PERFORMANCE ─────────────────────────────────────────
# Thread workers for detail fetching (0 = auto, recommended from CPU+RAM).
WORKERS=0
# Wait for network idle before parsing: False = faster, True = more complete.
NETWORK_IDLE=False
# Block images/CSS/fonts/ads for speed (recommended True).
BLOCK_RESOURCES=True
# Reuse the browser instance across requests when possible.
BROWSER_REUSE=True
# Max scrapers running in parallel (0 = auto from hardware).
MAX_CONCURRENT_SOURCES=0

# ── SCRAPING ────────────────────────────────────────────
# Random delay between requests, in seconds (default 2.0 - 5.0).
SCRAPING_DELAY_MIN=2.0
SCRAPING_DELAY_MAX=5.0

# Default lead limit when --limit is not passed (default 50).
DEFAULT_LIMIT=50

# Output directory for generated .xlsx / .json files (default: output).
OUTPUT_DIR=output

# ── EMAIL SCRAPING ──────────────────────────────────────
# Visit each lead's website to find an email. This is the slowest enrichment
# step; it is also auto-disabled for >3 sources or limit >30.
EMAIL_SCRAPING_ENABLED=True
# Per-site timeout in seconds (default 3).
EMAIL_SCRAPING_TIMEOUT=3
# Pages scanned per site: 1 = home only, 2 = home + contact (default 1).
EMAIL_SCRAPING_MAX_PAGES=1
# Parallel website fetches during email scraping (default 10).
EMAIL_SCRAPING_MAX_CONCURRENT=10
